# RADIUS configuration overrides (copy to .env and edit as needed).
# Every value is optional; defaults live in app/config.py.

# Default map center (Dago, Bandung)
RADIUS_DEFAULT_LAT=-6.9147
RADIUS_DEFAULT_LON=107.6098
RADIUS_DEFAULT_MINUTES=15

# Walking model
RADIUS_WALK_SPEED_KMH=4.5
RADIUS_ISOCHRONE_BUFFER_M=40

# Overpass behaviour
RADIUS_OVERPASS_TIMEOUT_S=40
RADIUS_OVERPASS_RETRIES=3
RADIUS_OVERPASS_BACKOFF_S=2.0

# Result cache
RADIUS_CACHE_TTL_HOURS=168

# Server
RADIUS_HOST=127.0.0.1
RADIUS_PORT=8000
